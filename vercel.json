{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/src/public/$1"
    },
    {
      "source": "/configure",
      "destination": "/app.js"
    },
    {
      "source": "/manifest.json",
      "destination": "/app.js"
    },
    {
      "source": "/:uuid/manifest.json",
      "destination": "/app.js"
    },
    {
      "source": "/stremio/:uuid/config/manifest.json",
      "destination": "/app.js"
    },
    {
      "source": "/catalog/:type/:catalogId.json",
      "destination": "/app.js"
    },
    {
      "source": "/:uuid/catalog/:type/:catalogId.json",
      "destination": "/app.js"
    },
    {
      "source": "/stremio/:uuid/catalog/:type/:catalogId.json",
      "destination": "/app.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/app.js"
    }
  ]
}